<Window x:Class="WPF1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF1"
        mc:Ignorable="d" Icon="/dados/5.png"
        Title="Projeto Final" Height="650" Width="800">
    <Grid>
        <Grid.Resources>
            <Style TargetType="MenuItem">
                <Setter Property="FontSize" Value="22" />
                <Setter Property="Foreground" Value="Navy"/>
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0"
                  Grid.Column="0">
            <Menu
                DockPanel.Dock="Top"
                >
                <MenuItem Header="Sair" Name="mnusair" Click="mnusair_Click" />
                <MenuItem Header="Dados" Name="mnudados" Click="mnudados_Click" />
                <MenuItem Header="IMC" Name="mnuimc" />

            </Menu>
        </DockPanel>
        <Frame Name="frm" Grid.Row="1" Source="/IMC.xaml" />
        <TextBlock Padding="23 5 23 5" Text="Status Bar" Grid.Row="2" Background="Black"
                   Foreground="Yellow"/>
    </Grid>
</Window>
