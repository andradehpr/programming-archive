<Page x:Class="WPF1.IMC"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WPF1"
      xmlns:vm="clr-namespace:WPF1.Controller"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" Background="Orange"
      Title="IMC">
    <Page.Resources>
        <vm:IMC_VM x:Key="vm" />
        <Style TargetType="TextBox" >
            <Setter Property="MinWidth" Value="300"></Setter>
        </Style>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock
            Background="Beige"
            Grid.Row="0" Text="Cálculo do IMC" Padding="3" FontSize="22" TextAlignment="Center"/>
        <StackPanel Grid.Row="1"  Margin="22" >
            <WrapPanel Margin="8">
                <Label MinWidth="100" HorizontalContentAlignment="Right" Padding="12 0">Altura</Label>
                <TextBox HorizontalAlignment="Stretch" Text="{Binding Altura, Mode=TwoWay, Source={StaticResource vm}}" ></TextBox>
            </WrapPanel>
            <WrapPanel Margin="8">
                <Label MinWidth="100" HorizontalContentAlignment="Right" Padding="12 0">Peso</Label>
                <TextBox HorizontalAlignment="Stretch"  Text="{Binding Peso, Mode=TwoWay, Source={StaticResource vm}}"></TextBox>
            </WrapPanel>
            <Button Width="200" Height="80" Content="Calcullar" 
                   
                    CommandParameter="{Binding Mode=OneWay, Source={StaticResource vm}}" Command="{Binding cmdimc, Source={StaticResource vm}}"  >
                
            </Button>
            <Border BorderBrush="Black"  Margin="12" BorderThickness="2" CornerRadius="22">
                <StackPanel>
                    <Label x:Name="taxa"  HorizontalContentAlignment="Center" Margin="12" Content="{Binding Taxa, Source={StaticResource vm}}" />
                    <Label Name="texto" HorizontalContentAlignment="Center" Margin="12" Content="{Binding Texto, Source={StaticResource vm}}"></Label>
                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</Page>
