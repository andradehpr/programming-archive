<Page x:Class="WPF1.JogoDados"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WPF1"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" Background="DarkGreen"
      Title="JogoDados">
    <Page.Resources>
        <local:Conversor x:Key="cvt"></local:Conversor>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock 
            Grid.Row="0" Grid.ColumnSpan="3"
            TextAlignment="Center"
            Foreground="White"
            FontSize="33"
            Padding="12"
            Text="Jogo dos Dados"></TextBlock>
        <Image 
            Name="img1" 
            Grid.Row="1" Grid.Column="0"
            Margin="12" Source="{Binding  Dado0, Converter={StaticResource cvt}, Mode=OneWay, 
            RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:JogoDados}}}" 
           />

        <Image 
            Name="img2" 
            Grid.Row="1" Grid.Column="2"
            Margin="12" Source="{Binding Dado1, Converter={StaticResource cvt}, 
            RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:JogoDados}}}"
           />
        <Border BorderThickness="5" 
                CornerRadius="12"
                Background="Wheat"
                Grid.Column="1" Grid.Row="1"
                BorderBrush="Black" Padding="12">
            <StackPanel Orientation="Vertical">
                <Label>Jogador</Label>
                <TextBox   Name="txtjogador"  Text="{Binding Jogador,Mode=TwoWay,RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:JogoDados}}}"/>
                <Label>Montante</Label>
                <TextBox  Name="txtmontante" Text="{Binding Montante,Mode=TwoWay, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:JogoDados}}}"/>
                <WrapPanel Orientation="Horizontal">
                    <Label>Aposta</Label>
                    <Label Name="lblaposta" 
                      Content="{Binding Value, ElementName=sldaposta}"></Label>

                </WrapPanel>
                 <Slider Name="sldaposta" 
                        Minimum="0"
                        Maximum="100"
                        TickFrequency="10"
                        TickPlacement="BottomRight"
                        IsSnapToTickEnabled="True"
                        Foreground="Black"
                        Margin="22"
                        ></Slider>
                <Button Content="Rolar" Click="Button_Click"
                        Background="YellowGreen"
                        Margin="35 22" 
                        HorizontalAlignment="Stretch"></Button>
                <Border Margin="22" Background="White" 
                        BorderBrush="Black" BorderThickness="1"
                        Padding="12"
                        CornerRadius="12">
                    <TextBlock Text="Mensagens" Name="tv"></TextBlock>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Page>
